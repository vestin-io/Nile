{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "baseUrl": "."
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx", "packages/**/*.d.ts", "apps/**/*.ts", "apps/**/*.tsx", "apps/**/*.d.ts"]
}

# Copy this file to apps/desktop/.env.release before running a signed local build.
# Usage:
#   set -a
#   source apps/desktop/.env.release
#   set +a
#   npm run build:app --prefix apps/desktop
#
# For an unsigned local packaging run, use:
#   npm run build:app:unsigned --prefix apps/desktop
#
# On Windows, local packaging uses the same build command and does not require
# the Apple signing variables in this file:
#   npm run build:app:unsigned --prefix apps/desktop

# Base64-encoded Developer ID Application .p12 certificate.
CSC_LINK=""

# Password used when exporting the .p12 certificate.
CSC_KEY_PASSWORD=""

# Apple Developer account email used for notarization.
APPLE_ID=""

# Apple app-specific password for notarization.
APPLE_APP_SPECIFIC_PASSWORD=""

# Apple Developer Team ID.
APPLE_TEAM_ID=""

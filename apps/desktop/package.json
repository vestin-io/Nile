{
  "name": "@nile/desktop",
  "productName": "Nile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.cjs",
  "dependencies": {
    "@lobehub/icons-static-svg": "^1.88.0",
    "@nile/core": "file:../../packages/core",
    "@nile/host-local": "file:../../packages/host-local",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19"
  },
  "scripts": {
    "build": "node --import tsx ./build.ts",
    "build:app": "npm run build && electron-builder --publish never",
    "build:app:dir": "npm run build && electron-builder --dir --publish never",
    "build:app:unsigned": "npm run build && env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never -c.mac.identity=null",
    "dev": "node --import tsx ./dev.ts",
    "icons": "node --import tsx ./generate-icons.ts",
    "start": "npm run build && node --import tsx ./launch.ts"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "dev.nile.desktop",
    "productName": "Nile",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icons/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "icon": "build/icons/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "extraMetadata": {
      "main": "dist/electron/main.cjs"
    }
  }
}

{
  "name": "@nile/desktop",
  "productName": "Nile",
  "version": "0.17.1",
  "private": true,
  "description": "Nile desktop app",
  "author": "Nile contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/vestin-io/Nile.git"
  },
  "type": "module",
  "main": "dist/electron/main.cjs",
  "dependencies": {
    "@radix-ui/react-switch": "^1.2.6",
    "emoji-picker-react": "^4.19.1",
    "update-electron-app": "^3.2.0"
  },
  "scripts": {
    "prebuild": "npm --prefix ../.. run build -w @nile/builtins && npm --prefix ../.. run build:host-local",
    "prebuild:release": "npm --prefix ../.. run build -w @nile/builtins && npm --prefix ../.. run build:host-local",
    "predev": "npm --prefix ../.. run build -w @nile/builtins && npm --prefix ../.. run build:host-local",
    "prestart": "npm --prefix ../.. run build -w @nile/builtins && npm --prefix ../.. run build:host-local",
    "build": "node --import tsx ./build.ts",
    "build:release": "node --import tsx ./build.ts --release",
    "clean:release": "node --import tsx ./clean-release.ts",
    "build:app": "npm run clean:release && npm run build:release && node --import tsx ./package-app.ts",
    "build:app:dir": "npm run clean:release && npm run build:release && node --import tsx ./package-app.ts --dir",
    "build:app:unsigned": "npm run clean:release && npm run build:release && node --import tsx ./package-app.ts --unsigned",
    "dev": "node --import tsx ./dev.ts",
    "icons": "node --import tsx ./generate-icons.ts",
    "start": "npm run build && node --import tsx ./launch.ts"
  },
  "devDependencies": {
    "@lobehub/icons-static-svg": "^1.88.0",
    "@nile/builtins": "file:../../packages/builtins",
    "@nile/core": "file:../../packages/core",
    "@nile/host-local": "file:../../packages/host-local",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "36.9.5",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19"
  },
  "build": {
    "appId": "dev.nile.desktop",
    "productName": "Nile",
    "electronVersion": "36.9.5",
    "asarUnpack": [
      "dist/electron/KeychainGenericPasswordHelper"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/electron/**/*",
      "dist/renderer/**/*",
      "build/icons/**/*",
      "package.json",
      "!**/*.map"
    ],
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "icon": "build/icons/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.png",
      "artifactName": "${productName}-${version}-win32-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraMetadata": {
      "main": "dist/electron/main.cjs"
    }
  }
}
